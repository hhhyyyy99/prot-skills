{
  "name": "prot-skills",
  "version": "0.0.4",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm app:sync && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pnpm app:sync && tauri dev",
    "tauri:build": "pnpm app:sync && tauri build",
    "app:sync": "tsx scripts/sync-app-metadata.ts",
    "app:check": "tsx scripts/sync-app-metadata.ts --check",
    "version:patch": "tsx scripts/release-version.ts patch",
    "version:minor": "tsx scripts/release-version.ts minor",
    "version:major": "tsx scripts/release-version.ts major",
    "release:version": "tsx scripts/release-version.ts",
    "release:tag": "tsx scripts/create-release-tag.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tokens": "tsx scripts/check-tokens.ts",
    "audit:visual": "tsx scripts/audit-visual.ts",
    "prepare": "husky",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2.0.0",
    "cmdk": "1.0.4",
    "lucide-react": "^0.294.0",
    "openai": "^6.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxlint --fix"
    ],
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "productName": "Prot Skills"
}
